<?xml version="1.0" encoding="utf-8"?>
<!--
    This file provides the overall configuration for your PreTeXt
    project. To edit the content of your document, open `source/main.ptx`
    (default location).
-->
<project>
  <targets>
    <target name="web">
      <format>html</format>
      <source>source/main.ptx</source>
      <publication>publication/publication.ptx</publication>
      <output-dir>output/web</output-dir>
      <xsl>xsl/c-programming-html.xsl</xsl>
      <!-- Needed even though this target's cmecode.mode stays "live": a few individual
           cmecode instances (gnuplot/popen examples) are marked forceStatic="yes" and
           always render as a static, read-only code block regardless of mode, which
           requires cmecode.root to resolve. Must be an ABSOLUTE path (see comment in
           xsl/c-programming-html.xsl for why). Machine-specific: update if this project
           is cloned somewhere else. -->
      <stringparam key="cmecode.root" value="/Users/dz00762/repos/C-Programming/CMeCodeDir/"/>
    </target>
    <target name="web-static">
      <!-- Same as "web", but every cmecode window is rendered as a plain, read-only,
           copy-pasteable code block (pulled from CMeCodeDir) instead of the live Thayer
           iframe. Use this to preview/proofread new content before its starting points are
           registered on code.thayer.dartmouth.edu, or to share a version of the book with
           readers who don't have Thayer network access. -->
      <format>html</format>
      <source>source/main.ptx</source>
      <publication>publication/publication.ptx</publication>
      <output-dir>output/web-static</output-dir>
      <xsl>xsl/c-programming-html.xsl</xsl>
      <!-- No <deploy-dir> here on purpose: PreTeXt's own deploy-dir/site mechanism requires
           EVERY deployed target to have one and always reserves the root for a site/ landing
           page, so it can't keep "web" unchanged at root while adding this one as a subfolder.
           Instead, deploy.sh builds this target and assembles both into gh-pages itself
           (this one under /static/, "web" untouched at root) via a git worktree. -->
      <stringparam key="cmecode.mode" value="static"/>
      <!-- Must be an ABSOLUTE path (see comment in xsl/c-programming-html.xsl for why).
           This is machine-specific: update it if this project is cloned somewhere else,
           or override per-build using pretext's stringparam command line option for
           cmecode.root, pointed at the desired absolute path. -->
      <stringparam key="cmecode.root" value="/Users/dz00762/repos/C-Programming/CMeCodeDir/"/>
    </target>
    <target name="web-client">
      <!-- Same as "web", but every cmecode window renders the new client-side coding tool
           (compiles and runs C entirely in the student's browser, no server) instead of the
           live Thayer iframe. Evaluation/prototype stage - see coding-window/README.md and
           that tool's own DEPLOYMENT.md. Not deployed by deploy.sh yet; build and preview
           locally with `pretext build web-client` / `pretext view web-client` until this is
           ready to fold into the real deploy. -->
      <format>html</format>
      <source>source/main.ptx</source>
      <publication>publication/publication.ptx</publication>
      <output-dir>output/web-client</output-dir>
      <xsl>xsl/c-programming-html.xsl</xsl>
      <stringparam key="cmecode.mode" value="client"/>
      <!-- Needed for the same reason "web" needs it despite staying "live": forceStatic="yes"
           elements (gnuplot/popen examples) always render statically regardless of mode, which
           requires cmecode.root to resolve. Must be an ABSOLUTE path (see comment in
           xsl/c-programming-html.xsl for why). Machine-specific: update if this project is
           cloned somewhere else. -->
      <stringparam key="cmecode.root" value="/Users/dz00762/repos/C-Programming/CMeCodeDir/"/>
      <!-- assets/_custom-styles.css was never actually wired into any build target (found
           while chasing a Denver-theme rendering bug) - PreTeXt copies everything under
           assets/ into <output>/external/ regardless, so the file silently existed in every
           build's output without ever being <link>'d into a page. This is the documented
           mechanism (see that file's own header comment) for including it: a relative URL,
           since the XSL emits it directly as a <link href="..."> for the browser to resolve,
           not a build-time filesystem path (unlike cmecode.root above). -->
      <stringparam key="html.css.extra" value="external/_custom-styles.css"/>
    </target>
    <target name="latex">
      <format>latex</format>
      <source>source/main.ptx</source>
      <publication>publication/publication.ptx</publication>
      <output-dir>output/latex</output-dir>
      <xsl>xsl/c-programming-latex.xsl</xsl>
    </target>
    <target name="pdf" pdf-method="pdflatex">
      <format>pdf</format>
      <source>source/main.ptx</source>
      <publication>publication/publication.ptx</publication>
      <output-dir>output/pdf</output-dir>
      <xsl>xsl/c-programming-latex.xsl</xsl>
    </target>
    <target name="subset">
      <format>html</format>
      <source>source/main.ptx</source>
      <publication>publication/publication.ptx</publication>
      <output-dir>output/subset</output-dir>
      <stringparam key="debug.skip-knowls" value="yes"/>
      <!-- edit this to change the section/chapter/etc. to include
           in your subset build -->
      <xmlid-root>ch-first</xmlid-root>
    </target>
  </targets>
  <executables>
      <latex>latex</latex>
      <pdflatex>pdflatex</pdflatex>
      <xelatex>xelatex</xelatex>
      <pdfsvg>pdf2svg</pdfsvg>
      <asy>asy</asy>
      <sage>sage</sage>
      <pdfpng>convert</pdfpng>
      <pdfeps>pdftops</pdfeps>
      <pdfcrop>pdf-crop-margins</pdfcrop>
      <pageres>pageres</pageres>
      <node>node</node>
      <liblouis>file2brl</liblouis>
    </executables>
</project>
