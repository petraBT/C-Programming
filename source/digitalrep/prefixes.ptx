              </cell>
            </row>
            <row>
              <cell right="medium">
                kibibyte
              </cell>
              <cell right="medium">
                KiB
              </cell>
              <cell halign="center" right="medium">
                <m>(2^{10})</m> = 1,024 bytes
              </cell>
            </row>
            <row>
              <cell right="medium">
