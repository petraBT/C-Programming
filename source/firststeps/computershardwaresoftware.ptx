        <reading-questions xml:id="computers-vocabulary-reading-questions">
            <title>Check your understanding!</title>

            <exercise xml:id="computers-vocabulary-reading-question1">
                <statement>
                    <p>Can you think of any examples of software that you have used recently?</p>
                </statement>
                <response/>
                <hint>
                  <p>
                    Do you use word processing software? How about spreadsheets? Or graphics programs?
                  </p>
                </hint>
            </exercise>
            <exercise xml:id="computers-vocabulary-reading-question2">
                <statement>
                    <p>What are some examples of program input that you can think of? How are you currently controlling your computer?</p>
                </statement>
                <response/>
                <hint>
                    <p>
                        Do you use a keyboard? A mouse? Other input devices?
                    </p>
                </hint>
            </exercise>
        </reading-questions>
     </section>
</chapter>
