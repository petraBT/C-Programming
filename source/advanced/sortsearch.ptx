                  </feedback>
               </choice>
               <choice>
                  <statement>
                     <p><pre>c=b; a=c; b=a;</pre></p>
                  </statement>
                  <feedback>
                     <p>Not quite. Try again!</p>
                  </feedback>
               </choice>
               <choice>
                  <statement>
                     <p><pre>a=b; b=c; c=a;</pre></p>
                  </statement>
                  <feedback>
                     <p>Not quite. Try again!</p>
                  </feedback>
               </choice>
               <choice>
                  <statement>
                     <p><pre>a=b; b=a;</pre></p>
                  </statement>
                  <feedback>
                     <p>Not quite. Try again!</p>
                  </feedback>
               </choice>
            </choices>
			</exercise>
		</reading-questions>
	</section>

